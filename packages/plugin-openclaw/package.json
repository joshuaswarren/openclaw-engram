{
  "name": "@remnic/plugin-openclaw",
  "version": "1.0.22",
  "description": "OpenClaw adapter for Remnic memory — thin wrapper delegating to @remnic/core",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "openclaw": {
    "plugin": "./openclaw.plugin.json",
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.4.8"
    },
    "build": {
      "openclawVersion": "2026.5.2",
      "pluginSdkVersion": "2026.5.2"
    },
    "install": {
      "minHostVersion": ">=2026.4.8"
    }
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "check-types": "tsc --noEmit",
    "plugin:inspect": "plugin-inspector check --config plugin-inspector.config.json --no-openclaw",
    "plugin:inspect:runtime": "pnpm run build && PLUGIN_INSPECTOR_EXECUTE_ISOLATED=1 plugin-inspector check --config plugin-inspector.config.json --no-openclaw --runtime --mock-sdk",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@remnic/core": "workspace:^",
    "openai": "^6.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.8"
  },
  "devDependencies": {
    "@openclaw/plugin-inspector": "0.3.10",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshuaswarren/remnic.git",
    "directory": "packages/plugin-openclaw"
  },
  "keywords": [
    "remnic",
    "memory",
    "openclaw",
    "adapter",
    "plugin"
  ]
}
