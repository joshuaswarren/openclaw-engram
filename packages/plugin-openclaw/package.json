{
  "name": "@remnic/plugin-openclaw",
  "version": "9.1.28",
  "description": "OpenClaw adapter for Remnic memory — thin wrapper delegating to @remnic/core",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "openclaw": {
    "plugin": "./openclaw.plugin.json",
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@remnic/core": "workspace:*"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshuaswarren/remnic.git",
    "directory": "packages/plugin-openclaw"
  },
  "keywords": ["remnic", "memory", "openclaw", "adapter", "plugin"]
}
